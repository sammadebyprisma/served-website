# Neon Postgres connection string
# Get from: https://neon.tech → your project → Connection string
DATABASE_URI=postgresql://user:password@host/dbname?sslmode=require

# Random secret for Payload JWT signing
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=your-secret-here

# Optional explicit app URL (no trailing slash)
# Local development: http://localhost:3000
# On Vercel, Payload will fall back to VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL automatically.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
